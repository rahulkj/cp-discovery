# Confluent Platform Discovery - Environment Variables Example
# Copy this file to .env and fill in your values
# Note: .env files are not automatically loaded. Use a tool like direnv or source the file manually:
#   source .env
#   cp-discovery --config configs/config-env-vars.yaml

# ============================================================================
# General Configuration
# ============================================================================
CLUSTER_NAME=production-cluster
OUTPUT_FORMAT=json
OUTPUT_FILE=discovery-report.json

# ============================================================================
# Kafka Configuration
# ============================================================================
KAFKA_BOOTSTRAP_SERVERS=broker1:9092,broker2:9092,broker3:9092
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_USER=admin
KAFKA_PASS=your-kafka-password

# Kafka SSL/TLS Configuration (optional)
KAFKA_SSL_CA_LOCATION=/path/to/ca-cert.pem
KAFKA_SSL_CERT_LOCATION=/path/to/client-cert.pem
KAFKA_SSL_KEY_LOCATION=/path/to/client-key.pem
KAFKA_SSL_KEY_PASSWORD=your-key-password

# ============================================================================
# Shared Authentication (applies to all components if not overridden)
# ============================================================================
CP_SHARED_USER=cp-admin
CP_SHARED_PASS=your-shared-password

# ============================================================================
# Schema Registry Configuration
# ============================================================================
SCHEMA_REGISTRY_URL=https://schema-registry:8081
SR_USER=sr-admin
SR_PASS=your-sr-password

# Schema Registry - Bearer Token (alternative to basic auth)
SR_BEARER_TOKEN=your-bearer-token

# Schema Registry - API Key (alternative to basic auth)
SR_API_KEY=your-api-key
SR_API_KEY_HEADER=X-API-Key

# Schema Registry - OAuth Configuration
SR_OAUTH_CLIENT_ID=your-client-id
SR_OAUTH_CLIENT_SECRET=your-client-secret
SR_OAUTH_TOKEN_URL=https://auth.example.com/oauth/token
SR_OAUTH_SCOPES=schema-registry.read schema-registry.write

# Schema Registry - LDAP Configuration
LDAP_SERVER=ldap://ldap.example.com:389
LDAP_USER=cn=admin,dc=example,dc=com
LDAP_PASS=your-ldap-password
LDAP_BASE_DN=dc=example,dc=com

# ============================================================================
# Kafka Connect Configuration
# ============================================================================
KAFKA_CONNECT_URL=https://kafka-connect:8083
CONNECT_USER=connect-admin
CONNECT_PASS=your-connect-password
CONNECT_BEARER_TOKEN=your-connect-token
CONNECT_API_KEY=your-connect-api-key
CONNECT_OAUTH_CLIENT_ID=your-connect-oauth-id
CONNECT_OAUTH_CLIENT_SECRET=your-connect-oauth-secret

# ============================================================================
# ksqlDB Configuration
# ============================================================================
KSQLDB_URL=https://ksqldb:8088
KSQLDB_USER=ksqldb-admin
KSQLDB_PASS=your-ksqldb-password
KSQLDB_BEARER_TOKEN=your-ksqldb-token
KSQLDB_API_KEY=your-ksqldb-api-key

# ============================================================================
# REST Proxy Configuration
# ============================================================================
REST_PROXY_URL=https://rest-proxy:8082
REST_PROXY_USER=rest-admin
REST_PROXY_PASS=your-rest-password

# ============================================================================
# Control Center Configuration
# ============================================================================
CONTROL_CENTER_URL=https://control-center:9021
C3_USER=c3-admin
C3_PASS=your-c3-password
C3_API_KEY=your-c3-api-key

# ============================================================================
# Prometheus Configuration
# ============================================================================
PROMETHEUS_URL=http://prometheus:9090
PROMETHEUS_USER=prometheus-admin
PROMETHEUS_PASS=your-prometheus-password

# ============================================================================
# Alertmanager Configuration
# ============================================================================
ALERTMANAGER_URL=http://alertmanager:9093
ALERTMANAGER_USER=alertmanager-admin
ALERTMANAGER_PASS=your-alertmanager-password

# ============================================================================
# OAuth Cluster Example
# ============================================================================
OAUTH_CLUSTER_NAME=oauth-cluster
OAUTH_KAFKA_BOOTSTRAP=oauth-broker:9092
OAUTH_KAFKA_USER=oauth-user
OAUTH_KAFKA_PASS=oauth-password
OAUTH_SR_URL=https://oauth-sr:8081
OAUTH_CONNECT_URL=https://oauth-connect:8083
OAUTH_KSQLDB_URL=https://oauth-ksqldb:8088

# ============================================================================
# API Key Cluster Example
# ============================================================================
API_KEY_CLUSTER_NAME=apikey-cluster
API_KEY_KAFKA_BOOTSTRAP=apikey-broker:9092
API_KEY_SR_URL=https://apikey-sr:8081
API_KEY_CONNECT_URL=https://apikey-connect:8083
API_KEY_C3_URL=https://apikey-c3:9021

# ============================================================================
# LDAP Cluster Example
# ============================================================================
LDAP_CLUSTER_NAME=ldap-cluster
LDAP_KAFKA_BOOTSTRAP=ldap-broker:9092
LDAP_KAFKA_USER=kafka-user
LDAP_KAFKA_PASS=kafka-password
LDAP_SR_URL=https://ldap-sr:8081
LDAP_CONNECT_URL=https://ldap-connect:8083

# ============================================================================
# Confluent Cloud Configuration
# ============================================================================
CCLOUD_CLUSTER_NAME=confluent-cloud
CCLOUD_BOOTSTRAP_SERVERS=pkc-xxxxx.us-east-1.aws.confluent.cloud:9092
CCLOUD_API_KEY=your-ccloud-api-key
CCLOUD_API_SECRET=your-ccloud-api-secret
CCLOUD_SR_URL=https://psrc-xxxxx.us-east-2.aws.confluent.cloud
CCLOUD_SR_KEY=your-ccloud-sr-key
CCLOUD_SR_SECRET=your-ccloud-sr-secret
